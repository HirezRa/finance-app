# ========================================
# 🔒 SECURITY - NEVER COMMIT THESE!
# ========================================

# Environment files with secrets
.env
.env.*
.env.local
.env.production
.env.development
!.env.example

# Private keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
private/
credentials/

# GitHub / CI tokens (narrow patterns — avoid *token* which ignores source like token-blacklist.service.ts)
ghp_*
github_pat_*

# ========================================
# Dependencies
# ========================================
node_modules/
.npm/
.yarn/
.pnp.*

# ========================================
# Build outputs
# ========================================
dist/
build/
.next/
out/
*.tsbuildinfo

# ========================================
# Database
# ========================================
*.db
*.sqlite
*.sqlite3
postgres-data/
redis-data/
data/
*.sql.gz
*.dump

# ========================================
# Logs (runtime only — not backend/src/modules/logs source)
# ========================================
/logs/
backend/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ========================================
# IDE and Editors
# ========================================
.idea/
.vscode/
*.swp
*.swo
*.sublime-*
*.code-workspace
.history/

# ========================================
# OS Files
# ========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ========================================
# Temporary files
# ========================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.cache

# ========================================
# Docker volumes (local data)
# ========================================
docker-data/
volumes/

# ========================================
# Test coverage
# ========================================
coverage/
.nyc_output/
*.lcov

# ========================================
# Deployment artifacts
# ========================================
*.tar.gz
*.zip
deploy_*/
*.tgz

# ========================================
# Prisma
# ========================================
prisma/migrations/**/migration_lock.toml

# Update system files (created at runtime with proper permissions)
.update-status.json
.update-requested
.update-history.json
.github-token

# Update data directory
update-data/
