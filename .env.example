# ============================================
# Finance App - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================

# --------------------------------------------
# Database
# --------------------------------------------
DATABASE_URL=postgresql://finance:YOUR_SECURE_PASSWORD@db:5432/finance_app

# Docker Compose: must match the password embedded in DATABASE_URL above
DB_PASSWORD=YOUR_SECURE_PASSWORD

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_URL=redis://redis:6379

# --------------------------------------------
# JWT Authentication
# Generate with: openssl rand -hex 32
# --------------------------------------------
JWT_SECRET=generate-a-64-character-hex-string-here
JWT_REFRESH_SECRET=generate-another-64-character-hex-string-here
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --------------------------------------------
# Encryption
# Generate with: openssl rand -hex 32
# MUST be exactly 64 hex characters!
# --------------------------------------------
ENCRYPTION_MASTER_KEY=generate-a-64-character-hex-string-for-encryption

# --------------------------------------------
# Application
# --------------------------------------------
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost:5173

# --------------------------------------------
# Optional: OLLAMA Integration
# --------------------------------------------
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Same base URL as OLLAMA_URL unless you split internal vs public endpoints
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=30000

# --------------------------------------------
# Optional: n8n Webhook Integration
# --------------------------------------------
N8N_ENABLED=false
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# --------------------------------------------
# Optional: SMTP Email
# --------------------------------------------
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --------------------------------------------
# Optional: GitHub (בדיקת עדכונים / מאגר פרטי)
# --------------------------------------------
# PAT עם scope repo (קריאה) — נדרש כשהמאגר פרטי
GITHUB_TOKEN=
# ברירת מחדל: HirezRa/finance-app
GITHUB_REPO=HirezRa/finance-app

# --------------------------------------------
# Optional: jobs & alerts
# --------------------------------------------
LARGE_EXPENSE_THRESHOLD=500
DAILY_SYNC_CRON=0 6 * * *
